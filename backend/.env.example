# ── AI(r)Drop Backend Environment Variables ───────────────────────────────────
# Copy to .env and fill in values. Never commit .env.
#
# Production stack (docker-compose.yml + docker-compose.prod.yml) loads backend/.env.production
# for the Django and Celery services — keep that file as the source of truth for prod secrets.

# Django
SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_ENV=local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
# When using ngrok or another tunnel, add its hostname (no scheme), e.g. abc123.ngrok-free.app
EXTRA_ALLOWED_HOSTS=
# Optional extra browser origins (e.g. https://your-app.vercel.app) if anything calls Django directly
EXTRA_CORS_ORIGINS=

# Database (use host `db` and internal port 5432 when running backend in Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/airdrop_works

# Redis (use host `redis` and port 6379 inside the Compose network)
REDIS_URL=redis://localhost:6379/0

# Anthropic (AI Judge)
ANTHROPIC_API_KEY=

# AI Core extraction boundary
# local: in-process Django app, remote: call external AI core service
AI_CORE_MODE=local
AI_CORE_API_BASE_URL=
AI_CORE_TIMEOUT_SECONDS=15

# Twitter API v2
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_MAX_RESULTS=20

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=airdrop-works/0.1 by your-reddit-username
REDDIT_MAX_RESULTS=25

# Discord crawler
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
DISCORD_MAX_MESSAGES=25

# Telegram crawler
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_MAX_MESSAGES=25

# Periodic crawler interval (minutes)
CRAWLER_BEAT_MINUTES=15

# SPORE graph/vector settings
SPORE_QDRANT_ENABLED=false
SPORE_QDRANT_URL=http://localhost:6333
SPORE_QDRANT_COLLECTION=spore_nodes
SPORE_QDRANT_TIMEOUT_SECONDS=5
SPORE_NEO4J_ENABLED=false
SPORE_NEO4J_URI=bolt://localhost:7687
SPORE_NEO4J_USER=neo4j
SPORE_NEO4J_PASSWORD=
SPORE_NEO4J_DATABASE=neo4j
SPORE_SPORULATION_BEAT_MINUTES=10
SPORE_ACTIVATION_TTL_SECONDS=900
SPORE_ENABLE_PHASE3=false
SPORE_AUDIT_RETENTION_DAYS=30

# Dynamic.xyz (wallet auth verification)
DYNAMIC_API_KEY=

# Stripe (white-label subscriptions — post-launch)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
# Per-user AI Judge plans + one-time credit packs (Stripe Price IDs)
STRIPE_PRICE_USER_PRO=
STRIPE_PRICE_USER_TEAM=
STRIPE_PRICE_CREDIT_50=
STRIPE_PRICE_CREDIT_200=
STRIPE_SUCCESS_URL=http://localhost:3000/settings?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/settings?billing=cancelled

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM_NAME=AI(r)Drop
EMAIL_FROM_ADDRESS=hello@airdrop.works

# Sentry
SENTRY_DSN=

# Docker Compose service credentials
DB_NAME=airdrop_works
DB_USER=postgres
DB_PASSWORD=postgres
