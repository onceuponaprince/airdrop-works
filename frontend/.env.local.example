# ── AI(r)Drop Frontend Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local.

# Backend (server-side only — Next.js rewrites proxy forwards /api/v1/* here)
BACKEND_URL=http://localhost:8000

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (waitlist only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (server-side only — for OTP table writes behind RLS)
# Get from Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Dynamic.xyz (Web3 wallet connect) — Environment ID from https://app.dynamic.xyz/
# Leave empty to disable the SDK locally (avoids failed fetch / nonce prefetch noise).
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Analytics
NEXT_PUBLIC_GA_ID=
# Vercel Analytics is zero-config when deployed to Vercel

# Error Tracking
NEXT_PUBLIC_SENTRY_DSN=

# Stripe (post-launch white-label)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI Judge (server-side only — never expose to client)
ANTHROPIC_API_KEY=

# Twitter/X API (server-side only — for account analysis feature)
TWITTER_BEARER_TOKEN=

# Twitter OAuth 2.0 (for waitlist Twitter connect step)
# Create app at developer.twitter.com → enable OAuth 2.0 → Web App type
# Scopes: tweet.read, users.read
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3000/api/auth/twitter/callback

# Resend (server-side — waitlist confirmation emails)
RESEND_API_KEY=
EMAIL_FROM_NAME=AI(r)Drop
EMAIL_FROM_ADDRESS=hello@airdrop.works
