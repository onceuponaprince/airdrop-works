# ── AI(r)Drop Frontend Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values. Never commit .env.local.

# Backend (server-side only — Next.js rewrites proxy forwards /api/v1/* here)
BACKEND_URL=http://localhost:8000

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (waitlist + email OTP verification via Supabase Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Particle Network (Web3 wallet connect) — from https://dashboard.particle.network
# Leave all empty to disable wallet features locally.
NEXT_PUBLIC_PROJECT_ID=
NEXT_PUBLIC_CLIENT_KEY=
NEXT_PUBLIC_APP_ID=

# Analytics
NEXT_PUBLIC_GA_ID=
# Vercel Analytics is zero-config when deployed to Vercel

# Error Tracking
NEXT_PUBLIC_SENTRY_DSN=

# Stripe (post-launch white-label)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI Judge (server-side only — never expose to client)
ANTHROPIC_API_KEY=

# Twitter/X API (server-side only — for account analysis feature)
TWITTER_BEARER_TOKEN=

# Twitter OAuth 2.0 (for waitlist Twitter connect step)
# Create app at developer.twitter.com → enable OAuth 2.0 → Web App type
# Scopes: tweet.read, users.read
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3000/api/auth/twitter/callback

# Admin bypass — type this password on the waitlist wallet step to skip to step 3.
# Leave empty to disable. Only you should know this value.
NEXT_PUBLIC_ADMIN_BYPASS=

# Resend (server-side — waitlist confirmation emails)
RESEND_API_KEY=
EMAIL_FROM_NAME=AI(r)Drop
EMAIL_FROM_ADDRESS=hello@airdrop.works
