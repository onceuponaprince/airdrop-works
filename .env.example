# ── AI(r)Drop — Unified Environment Variables ─────────────────────────────────
# Single source of truth for all services. Never commit .env.
# Copy this file to .env and fill in values:
#   cp .env.example .env

# ═══════════════════════════════════════════════════════════════════════════════
# SHARED (used by multiple services)
# ═══════════════════════════════════════════════════════════════════════════════

# Anthropic (AI Judge) — backend scoring + frontend server-side proxy
ANTHROPIC_API_KEY=

# Twitter/X API v2
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM_NAME=AI(r)Drop
EMAIL_FROM_ADDRESS=hello@airdrop.works

# Dynamic.xyz
DYNAMIC_API_KEY=
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:3000/settings?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/settings?billing=cancelled

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND (Django + DRF + Celery)
# ═══════════════════════════════════════════════════════════════════════════════

SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_ENV=local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database (use host `db` and internal port 5432 when running in Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/airdrop_works

# Redis (use host `redis` and port 6379 inside the Compose network)
REDIS_URL=redis://localhost:6379/0

# AI Core extraction boundary (local = in-process, remote = external service)
AI_CORE_MODE=local
AI_CORE_API_BASE_URL=
AI_CORE_TIMEOUT_SECONDS=15

# Crawler settings
TWITTER_MAX_RESULTS=20

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=airdrop-works/0.1 by your-reddit-username
REDDIT_MAX_RESULTS=25

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
DISCORD_MAX_MESSAGES=25

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_MAX_MESSAGES=25

CRAWLER_BEAT_MINUTES=15

# SPORE graph/vector settings
SPORE_QDRANT_ENABLED=false
SPORE_QDRANT_URL=http://localhost:6333
SPORE_QDRANT_COLLECTION=spore_nodes
SPORE_QDRANT_TIMEOUT_SECONDS=5
SPORE_NEO4J_ENABLED=false
SPORE_NEO4J_URI=bolt://localhost:7687
SPORE_NEO4J_USER=neo4j
SPORE_NEO4J_PASSWORD=
SPORE_NEO4J_DATABASE=neo4j
SPORE_SPORULATION_BEAT_MINUTES=10
SPORE_ACTIVATION_TTL_SECONDS=900
SPORE_ENABLE_PHASE3=false
SPORE_AUDIT_RETENTION_DAYS=30

# Docker Compose DB credentials
DB_NAME=airdrop_works
DB_USER=postgres
DB_PASSWORD=postgres

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND (Next.js)
# ═══════════════════════════════════════════════════════════════════════════════

BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GA_ID=

# ═══════════════════════════════════════════════════════════════════════════════
# CONTRACTS (Hardhat / Solidity)
# ═══════════════════════════════════════════════════════════════════════════════

# Deployer wallet — NEVER commit the real key
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPCs (public defaults are fine for testnet, use Infura/Alchemy for production)
FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org
AVAX_RPC=https://api.avax.network/ext/bc/C/rpc
BASE_RPC=https://mainnet.base.org

# Block explorer API key (Etherscan v2 multichain — for contract verification)
ETHERSCAN_API_KEY=

# Deployed contract addresses — Avalanche Fuji
FUJI_INNOVATOR_TOKEN=
FUJI_PROFILE_NFT=
FUJI_CAMPAIGN_ESCROW=
FUJI_REWARD_DISTRIBUTOR=

# Deployed contract addresses — Base Sepolia
BASE_SEPOLIA_INNOVATOR_TOKEN=
BASE_SEPOLIA_PROFILE_NFT=
BASE_SEPOLIA_CAMPAIGN_ESCROW=
BASE_SEPOLIA_REWARD_DISTRIBUTOR=
